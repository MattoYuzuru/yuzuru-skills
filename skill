#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P -- "$(dirname -- "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;
    *) SOURCE="${SOURCE_DIR}/${SOURCE}" ;;
  esac
done

REPO_ROOT="$(cd -P -- "$(dirname -- "$SOURCE")" && pwd)"
SKILLS_DIR="${REPO_ROOT}/skills"
CODEX_DIR="${YUZURU_CODEX_SKILLS_DIR:-${YUZURU_SKILLS_DIR:-${HOME}/.agents/skills}}"
CLAUDE_DIR="${YUZURU_CLAUDE_SKILLS_DIR:-${HOME}/.claude/skills}"

usage() {
  cat <<'EOF'
Usage:
  skill                        Open interactive skill installer
  skill list                   List repository skills and install status
  skill install                Open interactive skill installer
  skill install all            Install all repository skills, all their agents
  skill install NAME           Install one or more skills, all their agents
  skill install --agent AGENT NAME [NAME...]
                                Install one or more skills for one agent only
  skill uninstall NAME         Uninstall one or more repository-installed skills
  skill uninstall --agent AGENT NAME [NAME...]
                                Uninstall one or more skills for one agent only
  skill new NAME --description TEXT [--resources LIST] [--targets LIST]
                                Create a repository skill skeleton
  skill validate [NAME...|all] Validate skill structure and authoring rules
  skill update                 Pull latest repository changes
  skill doctor                 Show paths and status

AGENT is one of: codex, claude

A skill installs for the agents listed in its optional `skill.yaml` sidecar.
Legacy SKILL.md `agents:` frontmatter remains supported; no metadata means both.

Environment:
  YUZURU_CODEX_SKILLS_DIR   Override Codex skills directory (default: ~/.agents/skills)
  YUZURU_CLAUDE_SKILLS_DIR  Override Claude Code skills directory (default: ~/.claude/skills)
  YUZURU_SKILLS_DIR         Deprecated alias for YUZURU_CODEX_SKILLS_DIR
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

skill_names() {
  find "${SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d -exec sh -c '
    for dir do
      [ -f "$dir/SKILL.md" ] && basename "$dir"
    done
  ' sh {} + | sort
}

skill_path() {
  printf '%s/%s' "${SKILLS_DIR}" "$1"
}

skill_exists() {
  [ -f "$(skill_path "$1")/SKILL.md" ]
}

skill_description() {
  awk '
    /^description:/ {
      sub(/^description:[[:space:]]*/, "")
      print
      exit
    }
  ' "$(skill_path "$1")/SKILL.md"
}

# Prints the space-separated agent list from `skill.yaml`, falling back to the
# legacy SKILL.md `agents:` field. Missing metadata targets both agents.
skill_agents() {
  local raw metadata agent seen
  metadata="$(skill_path "$1")/skill.yaml"
  if [ -f "$metadata" ]; then
    raw="$(awk '
      /^targets:/ {
        sub(/^targets:[[:space:]]*/, "")
        print
        exit
      }
    ' "$metadata")"
    [ -n "$raw" ] || die "skill '$1' has skill.yaml without targets"
  else
    raw="$(awk '
      /^agents:/ {
        sub(/^agents:[[:space:]]*/, "")
        print
        exit
      }
    ' "$(skill_path "$1")/SKILL.md")"
  fi

  if [ -z "$raw" ]; then
    printf 'codex claude'
    return
  fi

  raw="${raw#\[}"
  raw="${raw%\]}"
  raw="${raw//,/ }"
  seen=' '
  for agent in $raw; do
    case "$agent" in
      codex|claude) ;;
      *) die "skill '$1' has unknown target '$agent'" ;;
    esac
    case "$seen" in
      *" $agent "*) ;;
      *)
        [ "$seen" = ' ' ] || printf ' '
        printf '%s' "$agent"
        seen="${seen}${agent} "
        ;;
    esac
  done
}

skill_targets_agent() {
  local name="$1" agent="$2" a
  for a in $(skill_agents "$name"); do
    [ "$a" = "$agent" ] && return 0
  done
  return 1
}

agent_dir() {
  case "$1" in
    codex) printf '%s' "$CODEX_DIR" ;;
    claude) printf '%s' "$CLAUDE_DIR" ;;
    *) die "unknown agent: $1 (expected codex or claude)" ;;
  esac
}

install_target() {
  printf '%s/%s' "$(agent_dir "$1")" "$2"
}

link_target() {
  if [ -L "$1" ]; then
    readlink "$1"
  fi
}

# $1 = agent, $2 = skill name
status_for() {
  local agent="$1" name="$2"
  local src dest target
  src="$(skill_path "$name")"
  dest="$(install_target "$agent" "$name")"

  if [ -L "$dest" ]; then
    target="$(link_target "$dest")"
    if [ "$target" = "$src" ]; then
      printf 'installed'
    else
      printf 'conflict'
    fi
  elif [ -e "$dest" ]; then
    printf 'conflict'
  else
    printf 'available'
  fi
}

# Summarizes a skill's status across all agents it targets, for the
# interactive installer's single toggle per skill.
skill_status_summary() {
  local name="$1" agent status any_installed any_available any_conflict
  any_installed=0
  any_available=0
  any_conflict=0

  for agent in $(skill_agents "$name"); do
    status="$(status_for "$agent" "$name")"
    case "$status" in
      installed) any_installed=1 ;;
      available) any_available=1 ;;
      conflict) any_conflict=1 ;;
    esac
  done

  if [ "$any_conflict" -eq 1 ]; then
    printf 'conflict'
  elif [ "$any_installed" -eq 1 ] && [ "$any_available" -eq 1 ]; then
    printf 'partial'
  elif [ "$any_installed" -eq 1 ]; then
    printf 'installed'
  else
    printf 'available'
  fi
}

# $1 = agent, $2 = skill name
install_one() {
  local agent="$1" name="$2"
  local src dest status dir

  skill_exists "$name" || die "unknown skill: $name"
  src="$(skill_path "$name")"
  dir="$(agent_dir "$agent")"
  dest="$(install_target "$agent" "$name")"
  status="$(status_for "$agent" "$name")"

  mkdir -p "$dir"

  case "$status" in
    installed)
      printf 'already installed: %s (%s)\n' "$name" "$agent"
      ;;
    available)
      ln -s "$src" "$dest"
      printf 'installed: %s (%s) -> %s\n' "$name" "$agent" "$src"
      ;;
    conflict)
      printf 'conflict: %s already exists and is not managed by this repo (%s)\n' "$dest" "$agent" >&2
      return 1
      ;;
  esac
}

# $1 = agent, $2 = skill name
uninstall_one() {
  local agent="$1" name="$2"
  local dest status

  skill_exists "$name" || die "unknown skill: $name"
  dest="$(install_target "$agent" "$name")"
  status="$(status_for "$agent" "$name")"

  case "$status" in
    installed)
      rm "$dest"
      printf 'uninstalled: %s (%s)\n' "$name" "$agent"
      ;;
    available)
      printf 'not installed: %s (%s)\n' "$name" "$agent"
      ;;
    conflict)
      printf 'refusing to remove unmanaged path: %s (%s)\n' "$dest" "$agent" >&2
      return 1
      ;;
  esac
}

# Installs/uninstalls a skill across the agent(s) it targets, or a single
# explicit agent when $2 is non-empty. $3 selects install_one/uninstall_one.
apply_for_name() {
  local name="$1" agent_filter="$2" action="$3" agent rc
  rc=0
  skill_exists "$name" || die "unknown skill: $name"

  if [ -n "$agent_filter" ]; then
    skill_targets_agent "$name" "$agent_filter" \
      || die "skill '$name' does not target agent '$agent_filter'"
    "$action" "$agent_filter" "$name" || rc=1
    return "$rc"
  fi

  for agent in $(skill_agents "$name"); do
    "$action" "$agent" "$name" || rc=1
  done
  return "$rc"
}

install_for_name() {
  apply_for_name "$1" "$2" install_one
}

uninstall_for_name() {
  apply_for_name "$1" "$2" uninstall_one
}

agent_status_or_dash() {
  local name="$1" agent="$2"
  if skill_targets_agent "$name" "$agent"; then
    status_for "$agent" "$name"
  else
    printf -- '-'
  fi
}

cmd_list() {
  local name desc
  printf '%-11s %-11s %-28s %s\n' 'CODEX' 'CLAUDE' 'SKILL' 'DESCRIPTION'
  printf '%-11s %-11s %-28s %s\n' '-----' '------' '-----' '-----------'
  while IFS= read -r name; do
    desc="$(skill_description "$name")"
    printf '%-11s %-11s %-28s %s\n' \
      "$(agent_status_or_dash "$name" codex)" \
      "$(agent_status_or_dash "$name" claude)" \
      "$name" "$desc"
  done < <(skill_names)
}

# Parses a leading "--agent AGENT" pair off "$@" if present, validates it,
# and prints it (empty when absent). Caller re-reads $# after shifting.
parse_agent_flag() {
  if [ "$#" -ge 2 ] && [ "$1" = "--agent" ]; then
    case "$2" in
      codex|claude) printf '%s' "$2" ;;
      *) die "unknown agent: $2 (expected codex or claude)" ;;
    esac
  fi
}

cmd_install() {
  local agent_filter arg failed
  failed=0
  agent_filter="$(parse_agent_flag "$@")"
  [ -n "$agent_filter" ] && shift 2

  if [ "$#" -eq 0 ]; then
    interactive_install
    return
  fi

  if [ "$1" = "all" ]; then
    while IFS= read -r arg; do
      install_for_name "$arg" "$agent_filter" || failed=1
    done < <(skill_names)
    return "$failed"
  fi

  for arg in "$@"; do
    install_for_name "$arg" "$agent_filter" || failed=1
  done
  return "$failed"
}

cmd_uninstall() {
  local agent_filter arg failed
  failed=0
  agent_filter="$(parse_agent_flag "$@")"
  [ -n "$agent_filter" ] && shift 2

  [ "$#" -gt 0 ] || die "uninstall requires at least one skill name"
  for arg in "$@"; do
    uninstall_for_name "$arg" "$agent_filter" || failed=1
  done
  return "$failed"
}

cmd_update() {
  command -v git >/dev/null 2>&1 || die "git is required"
  git -C "$REPO_ROOT" pull --ff-only
  printf 'updated repository: %s\n' "$REPO_ROOT"
  printf 'installed skills are symlinks, so no reinstall is needed.\n'
}

cmd_doctor() {
  printf 'repo:           %s\n' "$REPO_ROOT"
  printf 'skills dir:     %s\n' "$SKILLS_DIR"
  printf 'codex install:  %s\n' "$CODEX_DIR"
  printf 'claude install: %s\n' "$CLAUDE_DIR"
  printf 'command:        %s\n' "${BASH_SOURCE[0]}"
  printf '\n'
  cmd_list
}

cmd_new() {
  python3 "${REPO_ROOT}/scripts/new_skill.py" --skills-dir "$SKILLS_DIR" "$@"
}

cmd_validate() {
  python3 "${REPO_ROOT}/scripts/validate_skills.py" \
    --skills-dir "$SKILLS_DIR" --evals-dir "${REPO_ROOT}/evals" "$@"
}

interactive_install() {
  [ -t 0 ] && [ -t 1 ] || die "interactive install requires a terminal"
  command -v tput >/dev/null 2>&1 || die "interactive install requires tput"

  local names selected conflicts count i key cursor apply quit status marker pointer desc
  names=()
  selected=()
  conflicts=()
  cursor=0
  apply=0
  quit=0

  while IFS= read -r key; do
    names+=("$key")
    status="$(skill_status_summary "$key")"
    if [ "$status" = "installed" ]; then
      selected+=("1")
    else
      selected+=("0")
    fi
    if [ "$status" = "conflict" ]; then
      conflicts+=("1")
    else
      conflicts+=("0")
    fi
  done < <(skill_names)

  count="${#names[@]}"
  [ "$count" -gt 0 ] || die "no skills found in $SKILLS_DIR"

  tput civis || true
  trap 'tput cnorm || true' EXIT

  while [ "$quit" -eq 0 ]; do
    tput clear
    printf 'Yuzuru Skills\n'
    printf 'Codex install:  %s\n' "$CODEX_DIR"
    printf 'Claude install: %s\n\n' "$CLAUDE_DIR"
    printf 'Use arrows to move, Space to toggle, a=all, n=none, Enter=apply, q=quit.\n'
    printf 'Conflicts are shown as [!] and are not modified. A toggle applies to every\n'
    # Backticks below are documentation, not command substitution.
    # shellcheck disable=SC2016
    printf 'agent the skill targets; use `skill install --agent AGENT NAME` for one agent only.\n\n'

    i=0
    while [ "$i" -lt "$count" ]; do
      pointer=' '
      [ "$i" -eq "$cursor" ] && pointer='>'

      if [ "${conflicts[$i]}" = "1" ]; then
        marker='[!]'
      elif [ "${selected[$i]}" = "1" ]; then
        marker='[x]'
      else
        marker='[ ]'
      fi

      desc="$(skill_description "${names[$i]}")"
      printf '%s %s %-28s %s\n' "$pointer" "$marker" "${names[$i]}" "$desc"
      i=$((i + 1))
    done

    IFS= read -rsn1 key || break
    case "$key" in
      $'\x1b')
        IFS= read -rsn2 key || true
        case "$key" in
          '[A')
            cursor=$((cursor - 1))
            [ "$cursor" -lt 0 ] && cursor=$((count - 1))
            ;;
          '[B')
            cursor=$((cursor + 1))
            [ "$cursor" -ge "$count" ] && cursor=0
            ;;
        esac
        ;;
      ' ')
        if [ "${conflicts[$cursor]}" = "0" ]; then
          if [ "${selected[$cursor]}" = "1" ]; then
            selected[cursor]="0"
          else
            selected[cursor]="1"
          fi
        fi
        ;;
      a)
        i=0
        while [ "$i" -lt "$count" ]; do
          [ "${conflicts[$i]}" = "0" ] && selected[i]="1"
          i=$((i + 1))
        done
        ;;
      n)
        i=0
        while [ "$i" -lt "$count" ]; do
          [ "${conflicts[$i]}" = "0" ] && selected[i]="0"
          i=$((i + 1))
        done
        ;;
      q)
        quit=1
        ;;
      ''|$'\n'|$'\r')
        apply=1
        quit=1
        ;;
    esac
  done

  tput cnorm || true
  trap - EXIT

  if [ "$apply" -ne 1 ]; then
    printf 'cancelled\n'
    return 0
  fi

  printf 'applying selection...\n'
  i=0
  while [ "$i" -lt "$count" ]; do
    if [ "${conflicts[$i]}" = "0" ]; then
      if [ "${selected[$i]}" = "1" ]; then
        install_for_name "${names[$i]}" ""
      else
        uninstall_for_name "${names[$i]}" ""
      fi
    fi
    i=$((i + 1))
  done
}

main() {
  local command
  command="${1:-install}"
  [ "$#" -gt 0 ] && shift || true

  case "$command" in
    help|-h|--help)
      usage
      ;;
    list|ls)
      cmd_list
      ;;
    install|add)
      cmd_install "$@"
      ;;
    uninstall|remove|rm)
      cmd_uninstall "$@"
      ;;
    new|init)
      cmd_new "$@"
      ;;
    validate|check)
      cmd_validate "$@"
      ;;
    update|upgrade)
      cmd_update
      ;;
    doctor|status)
      cmd_doctor
      ;;
    *)
      usage >&2
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
